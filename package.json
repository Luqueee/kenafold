{
  "name": "kenafold",
  "private": true,
  "version": "0.0.1",
  "packageManager": "bun@1.3.5",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:ui": "turbo build --filter @kenafold/ui",
    "build:web": "turbo build --filter @kenafold/web",
    "build:app": "turbo build --filter @kenafold/app",
    "typecheck": "turbo typecheck",
    "lint": "turbo lint",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "overrides": {
    "@tanstack/router-generator": "1.120.20",
    "@tanstack/router-plugin": "1.120.20"
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.3.3",
    "typescript": "~5.9.3"
  }
}
